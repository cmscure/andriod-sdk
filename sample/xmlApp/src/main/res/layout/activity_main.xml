<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Hero Banner (global image: hero_banner) -->
        <com.cmscure.sdk.ui.CureImageView
            android:id="@+id/imageHeroBanner"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            app:cureImageKey="hero_banner" />

        <!-- App Logo (global image: app_logo) -->
        <com.cmscure.sdk.ui.CureImageView
            android:id="@+id/imageAppLogo"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginTop="16dp"
            android:scaleType="centerCrop"
            app:cureImageKey="app_logo" />

        <!-- Welcome Subtitle (home_screen / welcome_subtitle) -->
        <com.cmscure.sdk.ui.CureTextView
            android:id="@+id/textWelcomeSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:textColor="#888888"
            app:cureKey="welcome_subtitle"
            app:cureTab="home_screen"
            app:cureDefault="Manage content, your way." />

        <!-- CTA Button (home_screen / cta_button) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCta"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Get Started" />

        <!-- Featured Products -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Feature Products"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="4dp"
            android:background="#CCCCCC" />

        <LinearLayout
            android:id="@+id/containerProducts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />

        <!-- Language Section Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Language"
                android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textDirection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LTR"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textStyle="bold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:background="@android:color/transparent" />
        </LinearLayout>

        <Spinner
            android:id="@+id/spinnerLanguages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <!-- Color Palette -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Color Palette"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- primary_color -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <com.cmscure.sdk.ui.CureColorView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cureColorKey="primary_color"
                    app:cureAutoStart="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="primary"
                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall" />
            </LinearLayout>

            <!-- accent_color -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <com.cmscure.sdk.ui.CureColorView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cureColorKey="accent_color"
                    app:cureAutoStart="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="accent"
                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall" />
            </LinearLayout>

            <!-- background_color -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <com.cmscure.sdk.ui.CureColorView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cureColorKey="background_color"
                    app:cureAutoStart="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="background"
                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall" />
            </LinearLayout>
        </LinearLayout>

        <!-- Last Update Event -->
        <TextView
            android:id="@+id/textLastUpdate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Last update: —"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="#999999" />

        <!-- Manual Refresh -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRefresh"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Refresh" />

    </LinearLayout>

</ScrollView>
